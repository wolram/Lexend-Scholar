#!/bin/sh
# .githooks/pre-commit — LexendScholar
# Hook de pre-commit: roda SwiftLint nos arquivos Swift staged.
# Bloqueia o commit se houver erros de lint.
#
# Instalação: git config core.hooksPath .githooks
# (ou execute: make install-hooks)

set -e

# Cores
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BLUE='\033[0;34m'
RESET='\033[0m'

echo "${BLUE}==> Pre-commit: verificando qualidade do código...${RESET}"

# ─── SwiftLint ────────────────────────────────────────────────────────────────

# Verificar se SwiftLint está instalado
if ! command -v swiftlint &> /dev/null; then
  echo "${YELLOW}⚠  SwiftLint não encontrado. Instalando via Homebrew...${RESET}"

  if command -v brew &> /dev/null; then
    brew install swiftlint
  else
    echo "${RED}✗  Homebrew não encontrado. Instale SwiftLint manualmente:${RESET}"
    echo "    brew install swiftlint"
    echo ""
    echo "    Para instalar Homebrew: https://brew.sh"
    echo ""
    echo "${YELLOW}    Para pular este hook temporariamente (não recomendado):${RESET}"
    echo "    git commit --no-verify"
    exit 1
  fi
fi

# Coletar arquivos Swift staged (apenas arquivos adicionados, modificados ou renomeados)
STAGED_SWIFT_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.swift$' || true)

if [ -z "$STAGED_SWIFT_FILES" ]; then
  echo "${GREEN}✓  Nenhum arquivo Swift staged — pulando SwiftLint${RESET}"
  exit 0
fi

# Exibir arquivos que serão verificados
FILE_COUNT=$(echo "$STAGED_SWIFT_FILES" | wc -l | tr -d ' ')
echo "    Verificando $FILE_COUNT arquivo(s) Swift..."

# Rodar SwiftLint apenas nos arquivos staged
# Usa --use-stdin para cada arquivo individualmente
LINT_ERRORS=0
LINT_WARNINGS=0

for FILE in $STAGED_SWIFT_FILES; do
  if [ -f "$FILE" ]; then
    # Rodar SwiftLint no arquivo e capturar resultado
    RESULT=$(swiftlint lint \
      --config .swiftlint.yml \
      --path "$FILE" \
      --reporter emoji \
      2>&1) || true

    # Contar erros e warnings
    FILE_ERRORS=$(echo "$RESULT" | grep -c "❌" || true)
    FILE_WARNINGS=$(echo "$RESULT" | grep -c "⚠️" || true)

    LINT_ERRORS=$((LINT_ERRORS + FILE_ERRORS))
    LINT_WARNINGS=$((LINT_WARNINGS + FILE_WARNINGS))

    if [ "$FILE_ERRORS" -gt 0 ]; then
      echo "${RED}  ✗  $FILE${RESET}"
      echo "$RESULT" | grep "❌" | sed 's/^/      /'
    elif [ "$FILE_WARNINGS" -gt 0 ]; then
      echo "${YELLOW}  ⚠  $FILE${RESET}"
      echo "$RESULT" | grep "⚠️" | sed 's/^/      /'
    else
      echo "${GREEN}  ✓  $FILE${RESET}"
    fi
  fi
done

echo ""

# Exibir sumário
echo "    Resumo: ${RED}$LINT_ERRORS erro(s)${RESET}, ${YELLOW}$LINT_WARNINGS aviso(s)${RESET}"

if [ "$LINT_ERRORS" -gt 0 ]; then
  echo ""
  echo "${RED}✗  SwiftLint encontrou $LINT_ERRORS erro(s). Commit bloqueado.${RESET}"
  echo ""
  echo "    Corrija os erros acima antes de commitar."
  echo "    Para autocorrigir erros simples: ${BLUE}make lint-swift-fix${RESET}"
  echo "    Para ver todos os erros:         ${BLUE}make lint-swift${RESET}"
  echo ""
  echo "    Para pular este hook (não recomendado):"
  echo "    ${YELLOW}git commit --no-verify${RESET}"
  echo ""
  exit 1
fi

if [ "$LINT_WARNINGS" -gt 0 ]; then
  echo "${YELLOW}⚠  $LINT_WARNINGS aviso(s) de lint. Considere corrigir antes de mergear.${RESET}"
fi

echo "${GREEN}✓  SwiftLint: todos os checks passaram${RESET}"
echo ""

# ─── Verificações adicionais ──────────────────────────────────────────────────

# Verificar se há arquivos com merge conflicts não resolvidos
CONFLICT_FILES=$(git diff --cached --name-only | xargs grep -l "^<<<<<<< " 2>/dev/null || true)
if [ -n "$CONFLICT_FILES" ]; then
  echo "${RED}✗  Arquivos com conflitos de merge não resolvidos:${RESET}"
  echo "$CONFLICT_FILES" | sed 's/^/      /'
  exit 1
fi

# Verificar se há credenciais hardcoded (padrões comuns)
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM || true)
if [ -n "$STAGED_FILES" ]; then
  SECRET_PATTERNS="sk_live_|pk_live_|PRIVATE_KEY|BEGIN RSA|eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9\."
  SECRETS_FOUND=$(echo "$STAGED_FILES" | xargs grep -El "$SECRET_PATTERNS" 2>/dev/null || true)

  if [ -n "$SECRETS_FOUND" ]; then
    echo "${RED}✗  Possíveis credenciais hardcoded detectadas:${RESET}"
    echo "$SECRETS_FOUND" | sed 's/^/      /'
    echo ""
    echo "    Revise esses arquivos antes de commitar."
    echo "    Use variáveis de ambiente ou .xcconfig para secrets."
    exit 1
  fi
fi

echo "${GREEN}==> Pre-commit: todos os checks passaram!${RESET}"
exit 0
